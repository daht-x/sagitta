---
import type GenericTable from "./generic-table";

interface Props {
	details: GenericTable[];
}
const { details } = Astro.props;
---

<table>
	<thead>
		<tr>
			<th>Name</th>
			<th>Description</th>
		</tr>
	</thead>
	<tbody>
		{details.map(detail => (
		<tr>
			<td>
				<code>{detail.name}</code>
			</td>
			<td>{detail.description}</td>
		</tr>
		))}
	</tbody>
</table>
